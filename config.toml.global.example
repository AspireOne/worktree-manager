# ~/.config/wt/config.toml — global defaults (all repos on this machine)
# Repo-level .wt.config.toml overrides these values.

baseBranch   = "main"
worktreeRoot = ".trees"

# Optional manage UI theme overrides.
# [theme]
# accent = "#d7b36e"
# accentStrong = "#f0c98f"
# context = "#9fb7b2"
# success = "#acc795"
# warning = "#dda35f"
# danger = "#dc8f82"
# textPrimary = "#f0e4d2"
# textMuted = "#a89c8d"
# textDim = "#746b61"
