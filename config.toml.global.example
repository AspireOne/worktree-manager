# ~/.config/wt/config.toml — global defaults (all repos on this machine)
# Repo-level .wt.config.toml overrides these values.

baseBranch   = "main"
worktreeRoot = ".trees"

# Optional manage UI theme overrides.
# [theme]
# accent = "#91a7ff"
# accentStrong = "#c1ccff"
# context = "#aebbd0"
# success = "#7fd38b"
# warning = "#f0b85a"
# danger = "#f07f7f"
# textPrimary = "#f4f7fb"
# textLabel = "#cbd7e3"
# textMuted = "#9aa8b7"
# textDim = "#657386"
