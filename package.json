{
  "name": "@aspireone/wt",
  "version": "0.1.5",
  "description": "Minimal git worktree launcher for parallel Codex workflows",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "bin": {
    "wtc": "./bin/wtc.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "README.md",
    ".wt.config.toml.example",
    "config.toml.global.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./bin/wtc.js",
    "wtc": "node ./bin/wtc.js",
    "pack:check": "node ./scripts/pack-check.mjs",
    "release": "node ./scripts/release.mjs",
    "release:patch": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major"
  },
  "keywords": [
    "git",
    "worktree",
    "codex",
    "cli"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.6.2",
    "cli-truncate": "^6.0.0",
    "execa": "^9.6.1",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "toml": "^4.1.1"
  }
}
