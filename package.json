{
  "name": "@aspireone/wt",
  "version": "0.1.2",
  "description": "Minimal git worktree launcher for parallel Codex workflows",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "bin": {
    "wt": "./bin/wt.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "README.md",
    ".wt.config.toml.example",
    "config.toml.global.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./bin/wt.js",
    "pack:check": "pnpm publish --dry-run",
    "release": "node ./scripts/release.mjs",
    "release:patch": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major"
  },
  "keywords": [
    "git",
    "worktree",
    "codex",
    "cli"
  ],
  "license": "UNLICENSED"
}
